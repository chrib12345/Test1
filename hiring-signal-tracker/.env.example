# Hiring-Signal Tracker environment.
# No API keys are needed for the public ATS endpoints. Structure kept for the
# optional aggregator and for the Claude normalization / digest layer.

# --- Required ---
# SQLAlchemy URL. Use the psycopg (v3) driver.
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/hiring_tracker

# --- Required only for Phase 2 (normalize) and Phase 3 (digest) ---
# api.anthropic.com is reachable directly (bypasses the egress proxy).
ANTHROPIC_API_KEY=

# --- Optional ---
# Claude model used for title normalization + weekly digest.
ANTHROPIC_MODEL=claude-opus-4-8

# Diff engine: window (days) in which a new posting matching a recently-closed
# one on (title, department, location, description_hash) is flagged as a repost.
HST_REPOST_WINDOW_DAYS=45

# An open posting whose last_seen_at is older than this many days (relative to
# the company's most recent successful snapshot) is flagged stale.
HST_STALE_AFTER_DAYS=3

# Politeness for the custom-careers fallback adapter.
HST_USER_AGENT=hiring-signal-tracker/0.1 (+research; contact set in config)

# Optional paid aggregator (NOT used by the core build). Ask before enabling.
# AGGREGATOR_API_KEY=

# Set HST_LIVE=1 to let the adapter contract tests hit real ATS endpoints.
HST_LIVE=0
